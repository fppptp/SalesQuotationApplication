@using QTMSModel.Models
@model COM_Ms_SalesQuotationCharge
@{
    var isEdit = !string.IsNullOrWhiteSpace(Model.ChargeCode);
}

<div class="row g-3">
    <div class="col-md-3">
        <label asp-for="CompanyCode" class="form-label"></label>
        @if (isEdit)
        {
            <input asp-for="CompanyCode" class="form-control" readonly />
        }
        else
        {
            @await Component.InvokeAsync("CompanySearchLookup", new { name = "CompanyCode", value = Model.CompanyCode, cssClass = "form-control" })
        }
        <span asp-validation-for="CompanyCode" class="text-danger small"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Department" class="form-label">Department</label>
        <input asp-for="Department" class="form-control text-uppercase" placeholder="e.g. IB" readonly="@isEdit" />
    </div>
    <div class="col-md-3">
        <label asp-for="QuotationType" class="form-label">Quotation Type</label>
        <input asp-for="QuotationType" class="form-control text-uppercase" placeholder="e.g. FREIGHT" readonly="@isEdit" />
    </div>
    <div class="col-md-3">
        <label asp-for="ChargeCode" class="form-label">Code</label>
        <input asp-for="ChargeCode" class="form-control text-uppercase" placeholder="e.g. OFR" readonly="@isEdit" />
        <span asp-validation-for="ChargeCode" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="ChargeName" class="form-label">Name</label>
        <input asp-for="ChargeName" class="form-control" placeholder="e.g. Ocean Freight" />
    </div>
    <div class="col-md-6">
        <label asp-for="Remark" class="form-label">Remark</label>
        <input asp-for="Remark" class="form-control" />
    </div>
</div>
