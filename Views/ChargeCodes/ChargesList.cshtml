@using QTMSModel.Models
@model List<COM_Ms_SalesQuotationCharge>
@{
    ViewData["Title"] = "Charges List";
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h1 class="h3 mb-1">Charges List</h1>
        <p class="text-muted mb-0">Standard charge codes used across quotations</p>
    </div>
    <a asp-action="CreateCharge" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Create Charge
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">@L["Lbl_Keyword"]</label>
                <input type="text" name="keyword" value="@keyword" class="form-control"
                       placeholder="Code or name" />
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">@L["Btn_Search"]</button>
                <a asp-action="ChargesList" class="btn btn-outline-secondary">@L["Btn_Reset"]</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Company</th>
                    <th>Department</th>
                    <th>Quotation Type</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">No charge codes found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CompanyCode</td>
                            <td>@item.Department</td>
                            <td>@item.QuotationType</td>
                            <td class="fw-semibold font-monospace">@item.ChargeCode</td>
                            <td>@item.ChargeName</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="EditCharge"
                                       asp-route-companyCode="@item.CompanyCode"
                                       asp-route-department="@item.Department"
                                       asp-route-quotationType="@item.QuotationType"
                                       asp-route-chargeCode="@item.ChargeCode"
                                       class="btn btn-outline-secondary">@L["Btn_Edit"]</a>
                                    <form asp-action="DeleteCharge" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="companyCode" value="@item.CompanyCode" />
                                        <input type="hidden" name="department" value="@item.Department" />
                                        <input type="hidden" name="quotationType" value="@item.QuotationType" />
                                        <input type="hidden" name="chargeCode" value="@item.ChargeCode" />
                                        <button type="submit" class="btn btn-outline-danger"
                                                onclick="return confirm('Delete charge @item.ChargeCode?')">@L["Btn_Delete"]</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>