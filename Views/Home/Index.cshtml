@using QTMSModel.Models
@model List<COM_View_SalesQuotationDashboard>
@{
    ViewData["Title"] = "Dashboard";
}
@{
    var currentMonth = DateTime.Now.Month;
    var currentYear = DateTime.Now.Year;

    // Ensure we never operate on a null Model to prevent ArgumentNullException
    var modelList = Model ?? new List<COM_View_SalesQuotationDashboard>();

    var monthData = modelList.Where(x => x.QuotationDate.HasValue &&
        x.QuotationDate.Value.Month == currentMonth &&
        x.QuotationDate.Value.Year == currentYear);
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h1 class="h3 mb-1">Quotation Dashboard</h1>
        <p class="text-muted mb-0">Overview for freight forwarding quotation activity</p>
    </div>
    <a asp-controller="Quotations" asp-action="CreateQuotation" class="btn btn-primary">Create quotation</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card h-100">
            <div class="card-body">
                <div class="metric-label">Total Quotes</div>
                <div class="metric-value">@modelList.Count()</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card h-100">
            <div class="card-body">
                <div class="metric-label">Draft</div>
                <div class="metric-value">@modelList.Count(x => x.StatusNo == 0)</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card h-100">
            <div class="card-body">
                <div class="metric-label">Sent</div>
                <div class="metric-value">@modelList.Count(x => x.StatusNo == 1)</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card h-100">
            <div class="card-body">
                <div class="metric-label">Approved / Booked</div>
                <div class="metric-value">@modelList.Count(x => x.StatusNo >= 2)</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted text-uppercase">Current Month Sales</h2>
                <div class="display-6 fw-bold">
                    @monthData.Sum(x => x.GrandTotalFrieghtAmountTHB ?? 0).ToString("N2")
                </div>
                <p class="text-muted mb-0">Based on quotation date in the current month</p>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted text-uppercase">Current Month Profit</h2>
                <div class="display-6 fw-bold">
                    @monthData.Sum(x => x.TotalMargin ?? 0).ToString("N2")
                </div>
                <p class="text-muted mb-0">Sell amount minus cost amount</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Latest Quotations</h2>
        <a asp-controller="Quotations" asp-action="QuotationsList" class="btn btn-outline-secondary btn-sm">View all</a>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Quote No.</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th class="text-end">Grand Total</th>
                    <th class="text-end">Profit</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!modelList.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">No quotation data yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in modelList.OrderByDescending(x => x.QuotationDate).Take(10))
                    {
                        <tr>
                            <td class="fw-semibold">@item.QuotationNo</td>
                            <td>@item.QuotationDate?.ToString("dd/MM/yyyy")</td>
                            <td>@item.CustomerName</td>
                            <td>
                                <span class="badge text-bg-light border">
                                    @item.StatusName
                                </span>
                            </td>
                            <td class="text-end">
                                @item.CurrencyCode @item.GrandTotalFrieghtAmountTHB?.ToString("N2")
                            </td>
                            <td class="text-end">
                                @item.CurrencyCode @item.TotalMargin?.ToString("N2")
                            </td>
                            <td class="text-end">
                                <a asp-controller="Quotations"
                                       asp-action="QuotationDetails"
                                       asp-route-id="@item.QuotationNo"
                                       class="btn btn-sm btn-outline-primary">
                                    Open
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
