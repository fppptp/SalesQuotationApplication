@model IEnumerable<LMSModel.Models.COM_View_Agent>
@{
    ViewData["Title"] = L["Nav_Agents"];
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h1 class="h3 mb-1">@L["Nav_Agents"]</h1>
        <p class="text-muted mb-0">View agents available in the system (read-only from database view)</p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">@L["Lbl_Keyword"]</label>
                <input type="text" name="keyword" value="@keyword" class="form-control"
                       placeholder="Agent code or name" />
            </div>
            <div class="col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">@L["Btn_Search"]</button>
                <a asp-action="AgentsList" class="btn btn-outline-secondary">@L["Btn_Reset"]</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Phone</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No agents found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.custcode</strong></td>
                            <td>@item.custname</td>
                            <td>@item.contactn1</td>
                            <td>@item.phoneno</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
