@{
    var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Freight Quote Web</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light container py-3">
            <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">Freight Quote Web</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">@L["Nav_Dashboard"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Quotations" asp-action="Index">@L["Nav_Quotations"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Quotations" asp-action="Create">@L["Nav_NewQuotation"]</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">@L["Nav_Settings"]</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="ChargeCodes" asp-action="Index">@L["Nav_ChargeCodes"]</a></li>
                        </ul>
                    </li>
                </ul>

                <span class="small text-muted d-none d-xl-inline">@L["Nav_Tagline"]</span>

                <!-- Language switcher -->
                <form asp-controller="Language" asp-action="Set" method="post" class="m-0 ms-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl"
                           value="@(Context.Request.Path + Context.Request.QueryString)" />
                    <div class="btn-group btn-group-sm" role="group" aria-label="Language">
                        <button type="submit" name="culture" value="en"
                                class="btn @(lang == "en" ? "btn-primary" : "btn-outline-secondary")">EN</button>
                        <button type="submit" name="culture" value="th"
                                class="btn @(lang == "th" ? "btn-primary" : "btn-outline-secondary")">TH</button>
                    </div>
                </form>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-3 ms-3">
                        <span class="small text-muted">
                            @(User.FindFirst("DisplayName")?.Value ?? User.Identity.Name)
                        </span>
                        <form method="post" asp-controller="Account" asp-action="Logout" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">@L["Nav_Logout"]</button>
                        </form>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @if (TempData["Success"] is string successMessage)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top py-4 mt-5 bg-white">
        <div class="container small text-muted">
            Freight Quote Web • ASP.NET Core MVC + SQL Server
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/quote-editor.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

