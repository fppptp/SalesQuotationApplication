@{
    var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>@ViewData["Title"] - Freight Quote Web</title>

    <!--begin::Fonts-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <!--end::Fonts-->

    <!--begin::Third Party Plugin(OverlayScrollbars)-->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css"
          crossorigin="anonymous" />
    <!--end::Third Party Plugin(OverlayScrollbars)-->

    <!--begin::Third Party Plugin(Bootstrap Icons)-->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
          crossorigin="anonymous" />
    <!--end::Third Party Plugin(Bootstrap Icons)-->

    <!--begin::Required Plugin(AdminLTE)-->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/css/adminlte.min.css"
          crossorigin="anonymous" />
    <!--end::Required Plugin(AdminLTE)-->

    <!--begin::DataTables-->
    <link rel="stylesheet"
          href="https://cdn.datatables.net/2.2.2/css/dataTables.bootstrap5.min.css"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.datatables.net/responsive/3.0.4/css/responsive.bootstrap5.min.css"
          crossorigin="anonymous" />
    <!--end::DataTables-->

    <link rel="stylesheet" href="~/css/loading-overlay.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <!--begin::Loading Overlay-->
    <div id="loading-overlay" class="lo-overlay">
        <div class="lo-spinner"></div>
        <div class="lo-text"></div>
    </div>
    <!--end::Loading Overlay-->

    <!--begin::App Wrapper-->
    <div class="app-wrapper">

        <!--begin::Header-->
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <!--begin::Start Navbar Links-->
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                    <li class="nav-item d-none d-md-block">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">@L["Nav_Dashboard"]</a>
                    </li>
                    <li class="nav-item d-none d-md-block">
                        <a class="nav-link" asp-controller="Quotations" asp-action="QuotationsList">@L["Nav_Quotations"]</a>
                    </li>
                </ul>
                <!--end::Start Navbar Links-->

                <!--begin::End Navbar Links-->
                <ul class="navbar-nav ms-auto">
                    <!--begin::Language Switcher-->
                    <li class="nav-item">
                        <form asp-controller="Language" asp-action="Set" method="post" class="m-0 d-flex align-items-center h-100 px-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl"
                                   value="@(Context.Request.Path + Context.Request.QueryString)" />
                            <div class="btn-group btn-group-sm" role="group" aria-label="Language">
                                <button type="submit" name="culture" value="en"
                                        class="btn btn-sm @(lang == "en" ? "btn-primary" : "btn-outline-secondary")">
                                    EN
                                </button>
                                <button type="submit" name="culture" value="th"
                                        class="btn btn-sm @(lang == "th" ? "btn-primary" : "btn-outline-secondary")">
                                    TH
                                </button>
                            </div>
                        </form>
                    </li>
                    <!--end::Language Switcher-->

                    <!--begin::User Menu-->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown user-menu">
                            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                <span class="d-none d-md-inline">@(User.FindFirst("DisplayName")?.Value ?? User.Identity.Name)</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <span class="dropdown-item-text text-muted small">
                                        @(User.FindFirst("DisplayName")?.Value ?? User.Identity.Name)
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout" class="m-0">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>@L["Nav_Logout"]
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    <!--end::User Menu-->
                </ul>
                <!--end::End Navbar Links-->
            </div>
        </nav>
        <!--end::Header-->

        <!--begin::Sidebar-->
        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
            <!--begin::Sidebar Brand-->
            <div class="sidebar-brand">
                <a asp-controller="Home" asp-action="Index" class="brand-link">
                    <i class="bi bi-truck brand-image opacity-75 fs-4 ms-1"></i>
                    <span class="brand-text fw-light">Freight Quote Web</span>
                </a>
            </div>
            <!--end::Sidebar Brand-->

            <!--begin::Sidebar Wrapper-->
            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu"
                        data-accordion="false">

                        <!-- ── Dashboard ─────────────────────────────── -->
                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index"
                               class="nav-link @(currentController == "Home" ? "active" : "")">
                                <i class="nav-icon bi bi-speedometer2"></i>
                                <p>@L["Nav_Dashboard"]</p>
                            </a>
                        </li>

                        <!-- ── Quotation ─────────────────────────────── -->
                        <li class="nav-item @(currentController == "Quotations" ? "menu-open" : "")">
                            <a href="#"
                               class="nav-link @(currentController == "Quotations" ? "active" : "")">
                                <i class="nav-icon bi bi-file-earmark-text"></i>
                                <p>
                                    @L["Nav_Quotations"]
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a asp-controller="Quotations" asp-action="CreateQuotation"
                                       class="nav-link @(currentController == "Quotations" && currentAction == "CreateQuotation" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>@L["Nav_Quotation_Create"]</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="Quotations" asp-action="QuotationsList"
                                       class="nav-link @(currentController == "Quotations" && currentAction == "QuotationsList" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>@L["Nav_Quotations"]</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- ── Charge ────────────────────────────────── -->
                        <li class="nav-item @(currentController == "ChargeCodes" ? "menu-open" : "")">
                            <a href="#"
                               class="nav-link @(currentController == "ChargeCodes" ? "active" : "")">
                                <i class="nav-icon bi bi-tags"></i>
                                <p>
                                    @L["Nav_ChargeCodes"]
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a asp-controller="ChargeCodes" asp-action="CreateCharge"
                                       class="nav-link @(currentController == "ChargeCodes" && currentAction == "CreateCharge" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Create Charge</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="ChargeCodes" asp-action="ChargesList"
                                       class="nav-link @(currentController == "ChargeCodes" && currentAction == "ChargesList" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Charges List</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- ── Customer ──────────────────────────────── -->
                        <li class="nav-item @(currentController == "Customers" ? "menu-open" : "")">
                            <a href="#"
                               class="nav-link @(currentController == "Customers" ? "active" : "")">
                                <i class="nav-icon bi bi-people"></i>
                                <p>
                                    Customer
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                @* <li class="nav-item">
                                    <a asp-controller="Customers" asp-action="CreateCustomer"
                                       class="nav-link @(currentController == "Customers" && currentAction == "CreateCustomer" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Create Customer</p>
                                    </a>
                                </li> *@
                                <li class="nav-item">
                                    <a asp-controller="Customers" asp-action="CustomersList"
                                       class="nav-link @(currentController == "Customers" && currentAction == "CustomersList" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Customers List</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- ── Agent ─────────────────────────────────── -->
                        <li class="nav-item @(currentController == "Agents" ? "menu-open" : "")">
                            <a href="#"
                               class="nav-link @(currentController == "Agents" ? "active" : "")">
                                <i class="nav-icon bi bi-person-badge"></i>
                                <p>
                                    Agent
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                @* <li class="nav-item">
                                    <a asp-controller="Agents" asp-action="CreateAgent"
                                       class="nav-link @(currentController == "Agents" && currentAction == "CreateAgent" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Create Agent</p>
                                    </a>
                                </li> *@
                                <li class="nav-item">
                                    <a asp-controller="Agents" asp-action="AgentsList"
                                       class="nav-link @(currentController == "Agents" && currentAction == "AgentsList" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Agents List</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- ── Port ──────────────────────────────────── -->
                        <li class="nav-item @(currentController == "Ports" ? "menu-open" : "")">
                            <a href="#"
                               class="nav-link @(currentController == "Ports" ? "active" : "")">
                                <i class="nav-icon bi bi-geo-alt"></i>
                                <p>
                                    Port
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                @* <li class="nav-item">
                                    <a asp-controller="Ports" asp-action="CreatePort"
                                       class="nav-link @(currentController == "Ports" && currentAction == "CreatePort" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Create Port</p>
                                    </a>
                                </li> *@
                                <li class="nav-item">
                                    <a asp-controller="Ports" asp-action="PortsList"
                                       class="nav-link @(currentController == "Ports" && currentAction == "PortsList" ? "active" : "")">
                                        <i class="nav-icon bi bi-circle"></i>
                                        <p>Ports List</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- ── Setting ───────────────────────────────── -->
                        <li class="nav-header">@L["Nav_Settings"]</li>

                        <li class="nav-item">
                            <a href="#" class="nav-link" id="refresh-cache-link">
                                <i class="nav-icon bi bi-arrow-clockwise"></i>
                                <p>Re-Cache</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
            <!--end::Sidebar Wrapper-->
        </aside>
        <!--end::Sidebar-->

        <!--begin::App Main-->
        <main class="app-main">
            <!--begin::App Content Header-->
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0">@ViewData["Title"]</h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i></a></li>
                                @if (ViewData["BreadcrumbParent"] != null)
                                {
                                    <li class="breadcrumb-item">
                                        <a href="@ViewData["BreadcrumbParentUrl"]">@ViewData["BreadcrumbParent"]</a>
                                    </li>
                                }
                                <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            <!--end::App Content Header-->

            <!--begin::App Content-->
            <div class="app-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
            <!--end::App Content-->
        </main>
        <!--end::App Main-->

        <!--begin::Footer-->
        <footer class="app-footer">
            <div class="float-end d-none d-sm-inline">
                <small class="text-muted">@L["Nav_Tagline"]</small>
            </div>
            <strong>Freight Quote Web</strong> &bull; ASP.NET Core MVC + SQL Server
        </footer>
        <!--end::Footer-->

    </div>
    <!--end::App Wrapper-->

    <!--begin::Script-->
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/js/adminlte.min.js"
            crossorigin="anonymous"></script>
    <!--end::Script-->

    <!--begin::DataTables-->
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.bootstrap5.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.4/js/dataTables.responsive.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.4/js/responsive.bootstrap5.min.js"
            crossorigin="anonymous"></script>
    <!--end::DataTables-->

    <!--begin::OverlayScrollbars Configure-->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebarWrapper = document.querySelector('.sidebar-wrapper');
            const isMobile = window.innerWidth <= 992;
            if (sidebarWrapper && typeof OverlayScrollbarsGlobal !== 'undefined' && OverlayScrollbarsGlobal.OverlayScrollbars && !isMobile) {
                OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
                    scrollbars: { theme: 'os-theme-light', autoHide: 'leave', clickScroll: true }
                });
            }
        });
    </script>
    <!--end::OverlayScrollbars Configure-->

    <script src="~/js/loading-overlay.js" asp-append-version="true"></script>
    <script src="~/js/quote-editor.js" asp-append-version="true"></script>

    <script>
        (function(){
        const link = document.getElementById('refresh-cache-link');
        if (!link) return;
        link.addEventListener('click', function(e){
            e.preventDefault();
            const pTag = link.querySelector('p');
            const original = pTag ? pTag.innerText : link.innerText;
            const baseLabel = original.replace(/\s*\(\d{4}-\d{2}-\d{2} \d{2}:\d{2}\)/g, '').trim();
            if (pTag) pTag.innerText = '…'; else link.innerText = '…';
            LoadingOverlay.show('Refreshing master data cache…');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            fetch('/Admin/RefreshAllCachesJson', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token || ''
                }
            }).then(r => r.json())
            .then(j => {
                LoadingOverlay.hide();
                if (j && j.ok) {
                    const dt = new Date();
                    const pad = (n)=> n.toString().padStart(2,'0');
                    const ts = dt.getFullYear() + '-' + pad(dt.getMonth()+1) + '-' + pad(dt.getDate()) + ' ' + pad(dt.getHours()) + ':' + pad(dt.getMinutes());
                    const text = baseLabel + ' (' + ts + ')';
                    if (pTag) pTag.innerText = text; else link.innerText = text;
                } else {
                    if (pTag) pTag.innerText = '❌'; else link.innerText = '❌';
                    setTimeout(()=>{ if (pTag) pTag.innerText = original; else link.innerText = original; }, 1500);
                }
            }).catch(()=>{
                LoadingOverlay.hide();
                if (pTag) pTag.innerText = '❌'; else link.innerText = '❌';
                setTimeout(()=>{ if (pTag) pTag.innerText = original; else link.innerText = original; }, 1500);
            });
        });

        document.addEventListener('submit', function(e) {
            var form = e.target;
            if (!form || form.tagName !== 'FORM') return;
            if (form.querySelector('button[type="submit"].btn-primary')) {
                LoadingOverlay.show('Saving…');
            }
        });
        })();
    </script>

    @await Html.PartialAsync("_ValidationModal")

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

