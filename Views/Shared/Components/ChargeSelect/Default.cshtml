@model IReadOnlyList<QTMSModel.Models.COM_Ms_SalesQuotationCharge>
@{
    var name = (string)ViewData["Name"] ?? "ChargeCode";
    var value = (string?)ViewData["Value"];
    var css = (string)ViewData["CssClass"] ?? "form-select";
}
<select name="@name" class="@css">
    <option value="">-- Select charge --</option>
    @foreach (var item in Model)
    {
        <option value="@item.ChargeCode" selected="@(item.ChargeCode == value ? "selected" : null)">@item.ChargeCode - @item.ChargeName</option>
    }
</select>
