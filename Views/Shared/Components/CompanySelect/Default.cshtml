@model IReadOnlyList<FMSModel.Models.COM_MS_Company>
@{
    var name = (string)ViewData["Name"] ?? "CompanyCode";
    var value = (string?)ViewData["Value"];
    var css = (string)ViewData["CssClass"] ?? "form-select";
}
<select name="@name" class="@css">
    <option value="">-- Select company --</option>
    @foreach (var item in Model)
    {
        <option value="@item.CompanyCode" selected="@(item.CompanyCode == value ? "selected" : null)">@item.CompanyCode - @item.Company_Name_EN</option>
    }
</select>
<button type="button" id="refresh-companies-btn" class="btn btn-sm btn-outline-secondary mt-2">Refresh companies</button>

<script>
    (function(){
        const btn = document.getElementById('refresh-companies-btn');
        let select = document.querySelector('select[name="' + '@name' + '"]');
        btn?.addEventListener('click', function(){
            btn.disabled = true;
            fetch('/Quotations/RefreshCompanyCacheJson', { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value } })
                .then(r => r.json())
                .then(data => {
                    if (data && data.ok) {
                        // reload fragment
                        fetch('/Quotations/CompanyOptionsFragment?name=' + encodeURIComponent('@name') + '&value=' + encodeURIComponent('@value' ?? ''))
                            .then(r => r.text())
                            .then(html => {
                                // parse returned fragment and replace current select
                                const tmp = document.createElement('div');
                                tmp.innerHTML = html;
                                const newSelect = tmp.querySelector('select[name="' + '@name' + '"]');
                                if (newSelect && select) {
                                    select.replaceWith(newSelect);
                                    select = newSelect;
                                }
                            })
                            .finally(() => btn.disabled = false);
                    } else {
                        btn.disabled = false;
                    }
                })
                .catch(() => btn.disabled = false);
        });
    })();
</script>
