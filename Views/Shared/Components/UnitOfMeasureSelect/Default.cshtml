@model IReadOnlyList<QTMSModel.Models.COM_Ms_UnitOfMeasure>
@{
    var name = (string)ViewData["Name"] ?? "UnitOfMeasure";
    var value = (string?)ViewData["Value"];
    var css = (string)ViewData["CssClass"] ?? "form-select";
}
<select name="@name" class="@css">
    <option value="">-- Select unit --</option>
    @foreach (var item in Model)
    {
        <option value="@item.UnitCode" selected="@(item.UnitCode == value ? "selected" : null)">@item.UnitCode - @item.UnitName</option>
    }
</select>
