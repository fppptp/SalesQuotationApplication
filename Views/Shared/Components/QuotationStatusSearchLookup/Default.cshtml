@model IReadOnlyList<COMMONModel.Models.COM_Ms_Status>
@{
    var name = (string)ViewData["Name"] ?? "StatusName";
    var value = (string?)ViewData["Value"];
    var css = (string)ViewData["CssClass"] ?? "form-control";
    var disabled = ViewData["Disabled"] is true;
    var selected = Model.FirstOrDefault(x => x.StatusDescription == value);
    var displayText = selected?.StatusDescription ?? "";
}
@if (disabled)
{
    <input type="text" class="@css" value="@displayText" disabled />
    <input type="hidden" name="@name" value="@value" />
}
else
{
    <div class="sl-root"
         data-static="true"
         data-columns='[{"field":"code","header":"Status"}]'
         data-display-format="{code}"
         data-value-field="code">
        <script type="application/json" class="sl-options">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => new { code = x.StatusDescription, name = x.StatusDescription })))</script>
        <input type="hidden" class="sl-value" name="@name" value="@value" />
        <div class="sl-input-wrap">
            <input type="text" class="@css sl-display" value="@displayText" autocomplete="off" />
            <button type="button" class="sl-clear" title="Clear">&times;</button>
        </div>
        <div class="sl-dropdown" style="display:none">
            <div class="sl-grid-wrap">
                <table class="sl-grid">
                    <thead><tr></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="sl-empty" style="display:none">No results</div>
            <div class="sl-loading" style="display:none">Searching...</div>
            <div class="sl-info" style="display:none"></div>
        </div>
    </div>
}
