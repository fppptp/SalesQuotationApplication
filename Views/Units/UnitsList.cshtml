@model List<UOMLib.Models.COM_Ms_UnitOfMeasure>
@{
    ViewData["Title"] = L["Nav_Units"];
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h1 class="h3 mb-1">@L["Nav_Units"]</h1>
        <p class="text-muted mb-0">Manage units of measure used in quotation charge lines</p>
    </div>
    <a asp-action="CreateUnit" class="btn btn-primary">@L["Btn_Create"]</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">@L["Lbl_Keyword"]</label>
                <input type="text" name="keyword" value="@keyword" class="form-control"
                       placeholder="Code or name" />
            </div>
            <div class="col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">@L["Btn_Search"]</button>
                <a asp-action="UnitsList" class="btn btn-outline-secondary">@L["Btn_Reset"]</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Class</th>
                    <th>Symbol</th>
                    <th>Base?</th>
                    <th class="text-end">Factor</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No units found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.UnitCode</strong></td>
                            <td>@item.UnitName</td>
                            <td>@item.UnitCategoryCode</td>
                            <td>@item.Symbol</td>
                            <td>@(item.FactorTobase == 1m ? "✓" : "")</td>
                            <td class="text-end">@item.FactorTobase.ToString("N6")</td>
                            <td class="text-end">
                                <a asp-action="EditUnit" asp-route-id="@item.UnitCode"
                                   class="btn btn-sm btn-outline-primary">Edit</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
