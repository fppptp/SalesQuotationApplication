@using QTMSModel.Models
@model COM_Trs_SalesQuotation
@{
    ViewData["Title"] = L["Page_CreateQuotation"].Value;
    ViewData["BreadcrumbParent"] = L["Nav_Quotations"].Value;
    ViewData["BreadcrumbParentUrl"] = Url.Action("QuotationsList", "Quotations");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Create quotation</h1>
        <p class="text-muted mb-0">Build a freight forwarding quotation for customers in Thailand</p>
    </div>
    <a asp-action="QuotationsList" class="btn btn-outline-secondary">Back</a>
</div>

<form asp-action="CreateQuotation" method="post">
    <partial name="_QuotationForm" model="@Model" />
</form>
