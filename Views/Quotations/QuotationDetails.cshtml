@using QTMSModel.Models
@model COM_Trs_SalesQuotation
@{
    ViewData["Title"] = L["Page_QuotationDetails"].Value;
    ViewData["BreadcrumbParent"] = L["Nav_Quotations"].Value;
    ViewData["BreadcrumbParentUrl"] = Url.Action("QuotationsList", "Quotations");
}

<div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
    <div>
        <span class="badge text-bg-primary fs-6">@Model.QuotationNo</span>
        <span class="text-muted ms-2">@Model.CustomerName</span>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="EditQuotation" asp-route-id="@Model.QuotationNo" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>@L["Btn_Edit"]
        </a>
        <a asp-action="PrintQuotation" asp-route-id="@Model.QuotationNo" class="btn btn-outline-secondary" target="_blank">
            <i class="bi bi-printer me-1"></i>@L["Btn_Print"]
        </a>
        <a asp-action="QuotationsList" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>@L["Btn_Back"]
        </a>
    </div>
</div>

<div class="details-readonly">
    <fieldset disabled>
        <partial name="_QuotationForm" model="@Model" />
    </fieldset>
</div>